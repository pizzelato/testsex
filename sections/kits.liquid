
<section id="kits">
  <h2>Kits Especiais</h2>
  <div class="kits-grid">
    {% for product in collections['kits'].products %}
      <div class="kit-card">
        <img src="{{ product.featured_image | img_url: 'medium' }}" alt="{{ product.title }}">
        <h3>{{ product.title }}</h3>
        <p>{{ product.price | money }}</p>
        <a href="{{ product.url }}" class="btn">Comprar Kit</a>
      </div>
    {% endfor %}
  </div>
</section>
    